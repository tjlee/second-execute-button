<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.tjlee.secondexecutebutton</id>
    <name>Second Query Execution Button</name>
    <vendor>tjlee</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceImplementation="com.github.tjlee.secondexecutebutton.SecondExecuteSettings"/>
        <applicationConfigurable
            parentId="database.query.execution"
            instance="com.github.tjlee.secondexecutebutton.SecondExecuteConfigurable"
            id="com.github.tjlee.secondexecutebutton.settings"
            displayName="Second Query Execution Button"/>
    </extensions>

    <actions>
        <action id="com.github.tjlee.secondexecutebutton.SecondExecuteAction"
                class="com.github.tjlee.secondexecutebutton.SecondExecuteAction"
                text="Execute All as Separate Statements"
                description="Execute all statements in the script as separate statements"
                icon="AllIcons.Actions.RunAll">
            <add-to-group group-id="Console.Jdbc.Left"
                          anchor="after"
                          relative-to-action="Console.Jdbc.Execute"/>
        </action>
    </actions>
</idea-plugin>
